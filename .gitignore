# Python
__pycache__/
*.pyc
.venv/
venv/
env/
*.egg-info/

# Whisper / HuggingFace caches (don't commit the model)
.cache/
models/

# Local config / secrets
local.properties
.env
*.local

# OS / editors
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Android build output
stt-android/.gradle/
stt-android/build/
stt-android/app/build/
stt-android/captures/
stt-android/.externalNativeBuild/
stt-android/.cxx/

# Gradle wrapper jar is intentionally tracked, but leave local gradle caches out
.gradle/

# Windows-specific
*.log

# Local tooling / keys — never commit (everything in tools/ is local).
# Negation requires ignoring contents (tools/*), not the dir itself, so git
# still descends into the dir and matches the !exception below.
tools/*
!tools/server-watchdog.ps1
!tools/diagnose.ps1

# Local scratchpad for source images / videos before they get processed into
# .github/img/. The processed outputs live under .github/img/ and ARE pushed.
screenshots/
